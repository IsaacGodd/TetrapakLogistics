# Base de datos PostgreSQL
# Railway: pega la URL que te dan en el dashboard
# Local: postgresql://USER:PASSWORD@localhost:5432/tetrapak_db
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tetrapak_db"

# JWT — cambia esto por una cadena aleatoria larga
JWT_SECRET="cambia_esto_por_algo_secreto_y_largo"
JWT_EXPIRES_IN="7d"

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3001

# Frontend URL (para CORS)
FRONTEND_URL="http://localhost:5173"
